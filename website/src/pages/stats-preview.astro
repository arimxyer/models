---
import { AGENT_COUNT, DISPLAY, STATUS_PROVIDER_COUNT } from "@/data/site";

const base = import.meta.env.BASE_URL;

// Scatter plot: benchmark-like comparison data
const SCATTER_COUNT = 32;
const scatterDots = Array.from({ length: SCATTER_COUNT }, () => ({
  x: +(12 + Math.random() * 178).toFixed(1),
  y: +(10 + Math.random() * 78).toFixed(1),
  r: +(1.5 + Math.random() * 2).toFixed(1),
  opacity: +(0.35 + Math.random() * 0.65).toFixed(2),
}));

// Provider locations (approximate lat/lon of major AI providers)
const PROVIDER_LOCATIONS: [number, number][] = [
  [37.77, -122.42],
  [47.61, -122.33],
  [40.71, -74.01],
  [51.51, -0.13],
  [48.86, 2.35],
  [52.52, 13.41],
  [35.68, 139.69],
  [37.57, 126.98],
  [31.23, 121.47],
  [39.9, 116.4],
  [22.54, 114.06],
  [1.35, 103.82],
  [43.65, -79.38],
  [45.5, -73.57],
  [13.08, 80.27],
  [12.97, 77.59],
  [25.2, 55.27],
  [34.05, -118.24],
  [42.36, -71.06],
  [30.27, -97.74],
  [55.75, 37.62],
  [-33.87, 151.21],
  [50.07, 14.44],
  [59.33, 18.07],
  [32.07, 34.78],
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stats Preview — v3</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;600;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page">
      <h1 class="page-title">Stats Preview v3</h1>
      <p class="page-subtitle">
        Scroll to trigger · hover for subtle effect · click for easter egg
      </p>

      <!-- Galaxy Comparison -->
      <div class="galaxy-comparison">
        <div class="galaxy-option">
          <span class="option-label">Option 1 — Canvas 2D</span>
          <div class="galaxy-frame" data-accent="cyan">
            <canvas
              id="galaxy-canvas2d"
              width="400"
              height="400"
              aria-hidden="true"></canvas>
          </div>
          <span class="option-note"
            >~0KB extra · shadowBlur glow · rAF rotation</span
          >
        </div>
        <div class="galaxy-option">
          <span class="option-label">Option 2 — PixiJS WebGL</span>
          <div class="galaxy-frame galaxy-frame--tilted" data-accent="cyan">
            <div id="galaxy-pixi" style="width:400px;height:400px"></div>
          </div>
          <span class="option-note"
            >~150KB bundle · additive blend · GPU particles</span
          >
        </div>
      </div>

      <div style="height: 60vh"></div>

      <div class="stats-stack" id="stats-stack">
        <!-- Card 1: Model_Density — Galaxy SVG -->
        <div class="stat-card" data-stat-card data-accent="cyan">
          <div class="card-top">
            <span class="card-label">Model_Density</span>
          </div>
          <div class="card-body">
            <div
              class="card-number glow-cyan"
              data-count-target={DISPLAY.models}
            >
              0
            </div>
            <div
              id="galaxy-card-pixi"
              aria-hidden="true"
              class="card-graphic card-graphic--galaxy"
            >
            </div>
          </div>
        </div>

        <!-- Card 2: Bench_Validation — Scatter Plot -->
        <div class="stat-card" data-stat-card data-accent="magenta">
          <div class="card-top">
            <span class="card-label">Bench_Validation</span>
          </div>
          <div class="card-body">
            <div
              class="card-number glow-magenta"
              data-count-target={DISPLAY.benchmarks}
            >
              0
            </div>
            <svg
              class="card-graphic card-graphic--scatter"
              viewBox="0 0 200 100"
              aria-hidden="true"
            >
              <line
                x1="10"
                y1="92"
                x2="195"
                y2="92"
                stroke="var(--neon-magenta)"
                stroke-width="0.5"
                opacity="0.15"></line>
              <line
                x1="10"
                y1="8"
                x2="10"
                y2="92"
                stroke="var(--neon-magenta)"
                stroke-width="0.5"
                opacity="0.15"></line>
              <line
                x1="10"
                y1="50"
                x2="195"
                y2="50"
                stroke="var(--neon-magenta)"
                stroke-width="0.3"
                opacity="0.08"
                stroke-dasharray="4 3"></line>
              <line
                x1="100"
                y1="8"
                x2="100"
                y2="92"
                stroke="var(--neon-magenta)"
                stroke-width="0.3"
                opacity="0.08"
                stroke-dasharray="4 3"></line>
              <text
                x="102"
                y="99"
                fill="var(--neon-magenta)"
                font-size="5"
                font-family="'JetBrains Mono'"
                text-anchor="middle"
                opacity="0.25">QUALITY</text
              >
              <text
                x="3"
                y="52"
                fill="var(--neon-magenta)"
                font-size="5"
                font-family="'JetBrains Mono'"
                text-anchor="middle"
                opacity="0.25"
                transform="rotate(-90 3 52)">SPEED</text
              >
              {
                scatterDots.map((d) => (
                  <circle
                    cx={d.x}
                    cy={d.y}
                    r="0"
                    fill="var(--neon-magenta)"
                    class="scatter-dot"
                    data-target-r={d.r}
                    data-target-opacity={d.opacity}
                  />
                ))
              }
            </svg>
          </div>
        </div>

        <!-- Card 3: Provider_Nodes — Globe (cobe) -->
        <div class="stat-card" data-stat-card data-accent="green">
          <div class="card-top">
            <span class="card-label">Provider_Nodes</span>
          </div>
          <div class="card-body">
            <div
              class="card-number glow-green"
              data-count-target={String(STATUS_PROVIDER_COUNT)}
            >
              0
            </div>
            <canvas
              id="globe-canvas"
              class="card-graphic card-graphic--globe"
              width="240"
              height="240"
              aria-hidden="true"
              data-locations={JSON.stringify(PROVIDER_LOCATIONS)}></canvas>
          </div>
        </div>

        <!-- Card 4: Agent_Tracker — Animated Bot SVG -->
        <div class="stat-card" data-stat-card data-accent="amber">
          <div class="card-top">
            <span class="card-label">Agent_Tracker</span>
          </div>
          <div class="card-body">
            <div
              class="card-number glow-amber"
              data-count-target={String(AGENT_COUNT)}
            >
              0
            </div>
            <div
              class="card-graphic card-graphic--robot"
              id="bot-container"
              aria-hidden="true"
              data-svg-src={`${base}assets/stat-robot.svg`}
            >
            </div>
          </div>
        </div>
      </div>

      <div style="height: 40vh"></div>
    </div>

    <style>
      :root {
        --neon-cyan: #22d3ee;
        --neon-magenta: #f472b6;
        --neon-green: #4ade80;
        --neon-amber: #fbbf24;
        --bg-slate: #0f172a;
        --grid-color: rgba(34, 211, 238, 0.05);
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: "Outfit", sans-serif;
        background-color: var(--bg-slate);
        background-image:
          linear-gradient(var(--grid-color) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
        background-size: 40px 40px;
        color: #e2e8f0;
      }
      .page {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      .page-title {
        font-size: 1.5rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: white;
      }
      .page-subtitle {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        color: #64748b;
        margin-top: 0.25rem;
      }

      .stats-stack {
        display: grid;
        grid-template-rows: repeat(4, 1fr);
        gap: 4px;
        max-width: 500px;
        margin: 0 auto;
      }

      .stat-card {
        border: 1px solid rgba(34, 211, 238, 0.2);
        background: rgba(15, 23, 42, 0.8);
        display: flex;
        flex-direction: column;
        height: 170px;
        cursor: default;
        overflow: hidden;
        opacity: 0;
        transform: translateY(12px);
      }
      .stat-card[data-accent="magenta"] {
        border-color: rgba(244, 114, 182, 0.2);
      }
      .stat-card[data-accent="green"] {
        border-color: rgba(74, 222, 128, 0.2);
        border-left: 4px solid var(--neon-green);
      }
      .stat-card[data-accent="amber"] {
        border-color: rgba(251, 191, 36, 0.2);
      }

      .card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
      }
      .card-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #64748b;
      }

      .card-body {
        flex: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        padding: 0 16px 16px;
        position: relative;
      }

      .card-number {
        font-family: "JetBrains Mono", monospace;
        font-size: clamp(42px, 10vw, 56px);
        font-weight: 900;
        letter-spacing: -2px;
        font-variant-numeric: tabular-nums;
        line-height: 1;
        z-index: 1;
      }
      [data-accent="cyan"] .card-number {
        color: var(--neon-cyan);
      }
      [data-accent="magenta"] .card-number {
        color: var(--neon-magenta);
      }
      [data-accent="green"] .card-number {
        color: var(--neon-green);
      }
      [data-accent="amber"] .card-number {
        color: var(--neon-amber);
      }

      .glow-cyan {
        text-shadow: 0 0 10px rgba(34, 211, 238, 0.5);
      }
      .glow-magenta {
        text-shadow: 0 0 10px rgba(244, 114, 182, 0.5);
      }
      .glow-green {
        text-shadow: 0 0 10px rgba(74, 222, 128, 0.5);
      }
      .glow-amber {
        text-shadow: 0 0 10px rgba(251, 191, 36, 0.5);
      }

      /* Graphics */
      .card-graphic {
        align-self: flex-end;
      }
      .card-graphic--galaxy {
        width: 150px;
        height: 150px;
        perspective: 600px;
        opacity: 0;
        position: absolute;
        right: 8px;
        bottom: 8px;
      }
      .card-graphic--galaxy canvas {
        transform: rotateX(55deg);
        transform-origin: center center;
      }
      .card-graphic--scatter {
        width: 200px;
        height: 100px;
      }
      .card-graphic--globe {
        width: 120px;
        height: 120px;
      }
      .card-graphic--robot {
        width: 150px;
        height: 120px;
      }

      .scatter-dot {
        opacity: 0;
      }

      /* Galaxy comparison */
      .galaxy-comparison {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 3rem;
      }
      .galaxy-option {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
      }
      .option-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--neon-cyan);
      }
      .option-note {
        font-family: "JetBrains Mono", monospace;
        font-size: 9px;
        color: #475569;
        text-align: center;
      }
      .galaxy-frame {
        border: 1px solid rgba(34, 211, 238, 0.2);
        background: rgba(15, 23, 42, 0.8);
        width: 400px;
        height: 400px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .galaxy-frame canvas,
      .galaxy-frame div {
        display: block;
      }
      .galaxy-frame--tilted {
        perspective: 800px;
        overflow: visible;
      }
      .galaxy-frame--tilted > * {
        transform: rotateX(55deg);
        transform-origin: center center;
      }

      /* Reduced motion */
      @media (prefers-reduced-motion: reduce) {
        .stat-card {
          opacity: 1 !important;
          transform: none !important;
        }
        .card-graphic--galaxy {
          opacity: 1 !important;
        }
        .scatter-dot {
          opacity: 0.6 !important;
        }
      }
    </style>

    <script>
      import { animate, stagger, onScroll, utils } from "animejs";
      import createGlobe from "cobe";
      import type { Globe } from "cobe";
      import {
        Application,
        Graphics,
        Container,
        ParticleContainer,
        Particle,
        Texture,
        BlurFilter,
      } from "pixi.js";

      // =============================================
      // Galaxy Comparison: Canvas 2D vs PixiJS
      // =============================================

      interface StarParticle {
        x: number;
        y: number;
        size: number;
        opacity: number;
        hue: number; // 0=cyan core, 1=white edge
      }

      // Generate spiral galaxy particles
      function generateGalaxyParticles(
        count: number,
        radius: number,
      ): StarParticle[] {
        const particles: StarParticle[] = [];
        const arms = 3;
        const armSpread = 0.4;

        // Core cluster — dense center
        for (let i = 0; i < count * 0.3; i++) {
          const r = Math.random() * radius * 0.25;
          const angle = Math.random() * Math.PI * 2;
          particles.push({
            x: Math.cos(angle) * r,
            y: Math.sin(angle) * r,
            size: 0.5 + Math.random() * 2,
            opacity: 0.4 + Math.random() * 0.6,
            hue: Math.random() * 0.3, // mostly cyan
          });
        }

        // Spiral arms
        for (let i = 0; i < count * 0.7; i++) {
          const arm = Math.floor(Math.random() * arms);
          const armAngle = (arm / arms) * Math.PI * 2;
          const t = Math.random(); // 0=center, 1=edge
          const r = t * radius;
          const spiralAngle = armAngle + t * Math.PI * 2.5; // 2.5 full turns
          const scatter = armSpread * (0.2 + t * 0.8); // tighter at center
          const offsetAngle = spiralAngle + (Math.random() - 0.5) * scatter;
          const offsetR = r + (Math.random() - 0.5) * radius * 0.1;

          particles.push({
            x: Math.cos(offsetAngle) * offsetR,
            y: Math.sin(offsetAngle) * offsetR,
            size: 0.3 + Math.random() * 1.8 * (1 - t * 0.5), // larger near center
            opacity: (0.2 + Math.random() * 0.8) * (1 - t * 0.4), // brighter near center
            hue: t, // cyan at center → white at edges
          });
        }

        return particles;
      }

      // --- Option 1: Canvas 2D ---
      function initCanvas2DGalaxy(): void {
        const canvas = document.getElementById(
          "galaxy-canvas2d",
        ) as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const W = canvas.width;
        const H = canvas.height;
        const cx = W / 2;
        const cy = H / 2;
        const particles = generateGalaxyParticles(600, 160);
        let rotation = 0;

        function draw() {
          ctx!.clearRect(0, 0, W, H);
          ctx!.save();
          ctx!.translate(cx, cy);
          ctx!.rotate(rotation);

          for (const p of particles) {
            // Interpolate cyan → white based on hue
            const r = Math.round(34 + (255 - 34) * p.hue);
            const g = Math.round(211 + (255 - 211) * p.hue);
            const b = Math.round(238 + (255 - 238) * p.hue);
            const color = `rgba(${r},${g},${b},${p.opacity})`;

            ctx!.beginPath();
            ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx!.fillStyle = color;

            // Glow on larger particles
            if (p.size > 1.2) {
              ctx!.shadowColor = `rgba(34,211,238,${p.opacity * 0.6})`;
              ctx!.shadowBlur = p.size * 4;
            } else {
              ctx!.shadowBlur = 0;
            }

            ctx!.fill();
          }

          ctx!.restore();
          rotation += 0.001;
          requestAnimationFrame(draw);
        }

        draw();
      }

      // --- Option 2: PixiJS WebGL ---
      async function initPixiGalaxy(): Promise<void> {
        const el = document.getElementById("galaxy-pixi");
        if (!el) return;

        const app = new Application();
        await app.init({
          width: 400,
          height: 400,
          backgroundAlpha: 0,
          antialias: true,
          resolution: 2,
          autoDensity: true,
        });
        el.appendChild(app.canvas);

        const particles = generateGalaxyParticles(800, 160);
        const galaxyContainer = new Container();
        galaxyContainer.x = 200;
        galaxyContainer.y = 200;
        app.stage.addChild(galaxyContainer);

        // Glow layer (blurred, additive)
        const glowContainer = new Container();
        galaxyContainer.addChild(glowContainer);

        // Sharp layer on top
        const sharpContainer = new Container();
        galaxyContainer.addChild(sharpContainer);

        for (const p of particles) {
          const r = Math.round(34 + (255 - 34) * p.hue);
          const g = Math.round(211 + (255 - 211) * p.hue);
          const b = Math.round(238 + (255 - 238) * p.hue);
          const color = (r << 16) | (g << 8) | b;

          // Sharp dot
          const dot = new Graphics();
          dot.circle(0, 0, p.size);
          dot.fill({ color, alpha: p.opacity });
          dot.x = p.x;
          dot.y = p.y;
          sharpContainer.addChild(dot);

          // Glow dot (only for larger particles)
          if (p.size > 1.0) {
            const glow = new Graphics();
            glow.circle(0, 0, p.size * 2.5);
            glow.fill({ color: 0x22d3ee, alpha: p.opacity * 0.25 });
            glow.x = p.x;
            glow.y = p.y;
            glowContainer.addChild(glow);
          }
        }

        // Blur the glow layer
        glowContainer.filters = [new BlurFilter({ strength: 4 })];

        // Black hole — rendered on top of everything
        const blackHoleContainer = new Container();
        galaxyContainer.addChild(blackHoleContainer);

        const SPHERE_R = 14;

        // Accretion ring glow (outer, wide soft)
        const ringGlow = new Graphics();
        ringGlow.circle(0, 0, SPHERE_R + 10);
        ringGlow.stroke({ color: 0x22d3ee, alpha: 0.25, width: 8 });
        blackHoleContainer.addChild(ringGlow);
        ringGlow.filters = [new BlurFilter({ strength: 8 })];

        // Accretion ring (crisp inner)
        const ringInner = new Graphics();
        ringInner.circle(0, 0, SPHERE_R + 4);
        ringInner.stroke({ color: 0x22d3ee, alpha: 0.45, width: 1.5 });
        blackHoleContainer.addChild(ringInner);

        // Sphere: build from concentric circles to fake radial shading
        // Outermost = slightly lighter (rim light), center = pure black
        const sphereContainer = new Container();
        blackHoleContainer.addChild(sphereContainer);

        // Shadow/atmosphere halo behind sphere
        const halo = new Graphics();
        halo.circle(0, 0, SPHERE_R + 3);
        halo.fill({ color: 0x0a0f1e, alpha: 0.8 });
        sphereContainer.addChild(halo);
        halo.filters = [new BlurFilter({ strength: 3 })];

        // Concentric shading rings (outer=slightly lit, inner=dark)
        const rings = 12;
        for (let i = rings; i >= 0; i--) {
          const t = i / rings; // 1=outer edge, 0=center
          const r = SPHERE_R * (0.3 + t * 0.7);
          const ring = new Graphics();
          ring.circle(0, 0, r);
          // Outer rings: very dark blue-gray (ambient light). Inner: pure black.
          const brightness = Math.floor(t * t * 18); // quadratic falloff, max ~18
          const color =
            (brightness << 16) | ((brightness + 2) << 8) | (brightness + 8);
          ring.fill({ color, alpha: 1 });
          sphereContainer.addChild(ring);
        }

        // Specular highlight — upper-left, small bright spot
        const specular = new Graphics();
        specular.circle(-4, -5, 4);
        specular.fill({ color: 0x334155, alpha: 0.6 }); // slate-700 tint
        sphereContainer.addChild(specular);
        specular.filters = [new BlurFilter({ strength: 3 })];

        // Tight specular core
        const specCore = new Graphics();
        specCore.circle(-3.5, -4.5, 1.8);
        specCore.fill({ color: 0x64748b, alpha: 0.4 }); // slate-500
        sphereContainer.addChild(specCore);
        specCore.filters = [new BlurFilter({ strength: 1.5 })];

        // Rim light — subtle cyan edge glow on the lower-right
        const rimLight = new Graphics();
        rimLight.arc(0, 0, SPHERE_R - 1, Math.PI * 0.15, Math.PI * 0.65);
        rimLight.stroke({ color: 0x22d3ee, alpha: 0.2, width: 2 });
        sphereContainer.addChild(rimLight);
        rimLight.filters = [new BlurFilter({ strength: 2 })];

        // Hot spot orbiting accretion ring
        const hotSpot = new Graphics();
        hotSpot.circle(SPHERE_R + 6, 0, 2.5);
        hotSpot.fill({ color: 0xffffff, alpha: 0.6 });
        blackHoleContainer.addChild(hotSpot);
        hotSpot.filters = [new BlurFilter({ strength: 2 })];

        // Rotate galaxy, counter-rotate black hole accretion for visual interest
        app.ticker.add(() => {
          galaxyContainer.rotation += 0.001;
          blackHoleContainer.rotation -= 0.002; // accretion ring spins opposite
        });
      }

      // --- Card Galaxy (PixiJS, embedded in stat card) ---
      let cardGalaxySpeed = 0.001;
      let cardGalaxyTwinkle = false;
      let cardGalaxyTime = 0;
      const cardGalaxyDots: {
        particle: Particle;
        baseAlpha: number;
        phase: number;
      }[] = [];

      async function initCardGalaxy(): Promise<void> {
        const el = document.getElementById("galaxy-card-pixi");
        if (!el) return;

        const app = new Application();
        await app.init({
          width: 300,
          height: 300,
          backgroundAlpha: 0,
          antialias: true,
          resolution: 2,
          autoDensity: true,
        });
        app.canvas.style.width = "150px";
        app.canvas.style.height = "150px";
        el.appendChild(app.canvas);

        const particles = generateGalaxyParticles(600, 120);
        const galaxyContainer = new Container();
        galaxyContainer.x = 150;
        galaxyContainer.y = 150;
        app.stage.addChild(galaxyContainer);

        // Glow layer — regular Container + Graphics (needs BlurFilter)
        const glowContainer = new Container();
        galaxyContainer.addChild(glowContainer);

        // Sharp dots — ParticleContainer for GPU performance
        // Generate a small white circle texture to tint per-particle
        const dotGraphic = new Graphics();
        dotGraphic.circle(0, 0, 4);
        dotGraphic.fill({ color: 0xffffff });
        const dotTexture = app.renderer.generateTexture(dotGraphic);

        const sharpContainer = new ParticleContainer({
          dynamicProperties: {
            position: false,
            rotation: false,
            color: true, // needed for alpha twinkle
          },
        });
        galaxyContainer.addChild(sharpContainer);

        for (const p of particles) {
          const r = Math.round(34 + (255 - 34) * p.hue);
          const g = Math.round(211 + (255 - 211) * p.hue);
          const b = Math.round(238 + (255 - 238) * p.hue);
          const tint = (r << 16) | (g << 8) | b;

          const particle = new Particle({
            texture: dotTexture,
            x: p.x,
            y: p.y,
            scaleX: p.size / 4, // texture is r=4, scale to desired size
            scaleY: p.size / 4,
            tint,
            alpha: p.opacity,
          });
          sharpContainer.addParticle(particle);
          cardGalaxyDots.push({
            particle,
            baseAlpha: p.opacity,
            phase: Math.random() * Math.PI * 2,
          });

          // Glow dot (regular Graphics, only for larger particles)
          if (p.size > 1.0) {
            const glow = new Graphics();
            glow.circle(0, 0, p.size * 2.5);
            glow.fill({ color: 0x22d3ee, alpha: p.opacity * 0.25 });
            glow.x = p.x;
            glow.y = p.y;
            glowContainer.addChild(glow);
          }
        }

        glowContainer.filters = [new BlurFilter({ strength: 4 })];

        // Black hole sphere
        const blackHoleContainer = new Container();
        galaxyContainer.addChild(blackHoleContainer);

        const SPHERE_R = 10;

        const ringGlow = new Graphics();
        ringGlow.circle(0, 0, SPHERE_R + 8);
        ringGlow.stroke({ color: 0x22d3ee, alpha: 0.25, width: 6 });
        blackHoleContainer.addChild(ringGlow);
        ringGlow.filters = [new BlurFilter({ strength: 6 })];

        const ringInner = new Graphics();
        ringInner.circle(0, 0, SPHERE_R + 3);
        ringInner.stroke({ color: 0x22d3ee, alpha: 0.45, width: 1.5 });
        blackHoleContainer.addChild(ringInner);

        const sphereContainer = new Container();
        blackHoleContainer.addChild(sphereContainer);

        const halo = new Graphics();
        halo.circle(0, 0, SPHERE_R + 2);
        halo.fill({ color: 0x0a0f1e, alpha: 0.8 });
        sphereContainer.addChild(halo);
        halo.filters = [new BlurFilter({ strength: 3 })];

        const rings = 10;
        for (let i = rings; i >= 0; i--) {
          const t = i / rings;
          const r = SPHERE_R * (0.3 + t * 0.7);
          const ring = new Graphics();
          ring.circle(0, 0, r);
          const brightness = Math.floor(t * t * 18);
          const color =
            (brightness << 16) | ((brightness + 2) << 8) | (brightness + 8);
          ring.fill({ color, alpha: 1 });
          sphereContainer.addChild(ring);
        }

        const specular = new Graphics();
        specular.circle(-3, -4, 3);
        specular.fill({ color: 0x334155, alpha: 0.6 });
        sphereContainer.addChild(specular);
        specular.filters = [new BlurFilter({ strength: 2.5 })];

        const specCore = new Graphics();
        specCore.circle(-2.5, -3.5, 1.5);
        specCore.fill({ color: 0x64748b, alpha: 0.4 });
        sphereContainer.addChild(specCore);
        specCore.filters = [new BlurFilter({ strength: 1.5 })];

        const rimLight = new Graphics();
        rimLight.arc(0, 0, SPHERE_R - 1, Math.PI * 0.15, Math.PI * 0.65);
        rimLight.stroke({ color: 0x22d3ee, alpha: 0.2, width: 1.5 });
        sphereContainer.addChild(rimLight);
        rimLight.filters = [new BlurFilter({ strength: 2 })];

        const hotSpot = new Graphics();
        hotSpot.circle(SPHERE_R + 4, 0, 2);
        hotSpot.fill({ color: 0xffffff, alpha: 0.6 });
        blackHoleContainer.addChild(hotSpot);
        hotSpot.filters = [new BlurFilter({ strength: 2 })];

        app.ticker.add(() => {
          galaxyContainer.rotation += cardGalaxySpeed;
          blackHoleContainer.rotation -= cardGalaxySpeed * 2;

          // Twinkle: sparse particles briefly flare bright, most stay at base
          if (cardGalaxyTwinkle) {
            cardGalaxyTime += 0.02;
            for (const { particle, baseAlpha, phase } of cardGalaxyDots) {
              // Each particle's sine wave — only the peak (>0.85) triggers a flare
              const wave = Math.sin(cardGalaxyTime * 0.8 + phase * 6);
              if (wave > 0.85) {
                const flare = (wave - 0.85) / 0.15; // 0→1 during the narrow peak
                particle.alpha = Math.min(1, baseAlpha + flare * 0.5);
              } else {
                particle.alpha = baseAlpha;
              }
            }
          }
        });
      }

      initCanvas2DGalaxy();
      initPixiGalaxy();

      // --- Number counter ---
      function countUp(
        el: HTMLElement,
        target: string,
        duration: number,
      ): void {
        const match = target.match(/^([\d,]+)(.*)$/);
        if (!match) {
          el.textContent = target;
          return;
        }
        const num = parseInt(match[1].replace(/,/g, ""), 10);
        const suffix = match[2];
        const counter = { value: 0 };
        animate(counter, {
          value: num,
          duration,
          ease: "outExpo",
          modifier: utils.round(0),
          onRender: () => {
            el.textContent = counter.value.toLocaleString("en-US") + suffix;
          },
        });
      }

      // --- Animated Bot SVG ---
      async function initRobot(): Promise<void> {
        const container = document.getElementById("bot-container");
        if (!container) return;

        // Fetch and inject SVG so we can access internal elements
        const src = container.dataset.svgSrc;
        if (!src) return;
        const res = await fetch(src);
        const svgText = await res.text();
        container.innerHTML = svgText;

        const svg = container.querySelector("svg");
        if (!svg) return;
        svg.style.width = "100%";
        svg.style.height = "100%";

        // Idle: character floats gently — slow, subtle, continuous
        animate("#bot-character", {
          translateY: 70,
          duration: 2500,
          ease: "inOutSine",
          loop: true,
          alternate: true,
        });

        // Secondary motion: head lags behind body
        animate("#bot-head-wrap", {
          translateY: 3,
          duration: 2800,
          ease: "inOutSine",
          loop: true,
          alternate: true,
        });

        // Secondary motion: visor/eyes follow head with extra lag
        animate("#bot-visor-wrap, #bot-eye-l-wrap, #bot-eye-r-wrap", {
          translateY: 2,
          duration: 3000,
          ease: "inOutSine",
          loop: true,
          alternate: true,
        });

        // Secondary motion: arms sway with offset timing
        animate("#bot-hand-l-wrap", {
          translateY: 4,
          translateX: -1,
          duration: 2900,
          ease: "inOutSine",
          loop: true,
          alternate: true,
        });
        animate("#bot-hand-r-wrap", {
          translateY: 3,
          translateX: 1,
          duration: 3100,
          ease: "inOutSine",
          loop: true,
          alternate: true,
        });

        // Secondary motion: ears drift independently
        animate("#bot-ear-l-wrap", {
          translateY: 2,
          translateX: -1,
          duration: 3300,
          ease: "inOutSine",
          loop: true,
          alternate: true,
        });
        animate("#bot-ear-r-wrap", {
          translateY: 2,
          translateX: 1,
          duration: 3000,
          ease: "inOutSine",
          loop: true,
          alternate: true,
        });

        // Idle: shadow floats gently — slow, subtle, continuous
        animate("#bot-shadow", {
          duration: 2500,
          ease: "inOutSine",
          loop: true,
          alternate: true,
          opacity: 0.25,
        });

        // Hover: eyes blink
        const card = document.querySelector('[data-accent="amber"]');
        card?.addEventListener("mouseenter", () => {
          animate("#bot-eye-l, #bot-eye-r", {
            opacity: [1, 0, 1],
            duration: 250,
            ease: "inOutQuad",
          });
        });

        // Click: robot swap — current exits right, new one enters left
        const eyeColors = [
          "rgb(125,138,255)", // #1 original blue-purple
          "rgb(34,211,238)", // #2 cyan
          "rgb(244,114,182)", // #3 magenta
          "rgb(74,222,128)", // #4 green
          "rgb(251,191,36)", // #5 amber
          "rgb(239,68,68)", // #6 red
          "rgb(168,85,247)", // #7 purple
          "rgb(59,130,246)", // #8 blue
          "rgb(20,184,166)", // #9 teal
          "rgb(245,158,11)", // #10 orange
          "rgb(236,72,153)", // #11 pink
        ];
        let botIndex = 0;
        let swapping = false;

        // Add number label to the body — large watermark centered on torso
        const botBody = container!.querySelector("#bot-body");
        const svgNs = "http://www.w3.org/2000/svg";
        const numLabel = document.createElementNS(svgNs, "text");
        numLabel.setAttribute("x", "-23");
        numLabel.setAttribute("y", "235");
        numLabel.setAttribute("text-anchor", "middle");
        numLabel.setAttribute("font-size", "140");
        numLabel.setAttribute("font-family", "'JetBrains Mono', monospace");
        numLabel.setAttribute("font-weight", "900");
        numLabel.setAttribute("fill", eyeColors[0]);
        numLabel.setAttribute("opacity", "1");
        numLabel.textContent = "1";
        botBody?.appendChild(numLabel);

        function setBot(index: number) {
          const color = eyeColors[index % eyeColors.length];
          // Update eye colors
          container!
            .querySelectorAll("#bot-eye-l path, #bot-eye-r path")
            .forEach((p) => {
              if ((p as SVGElement).getAttribute("fill")?.startsWith("rgb")) {
                (p as SVGElement).setAttribute("fill", color);
              }
            });
          // Update number + match color to eyes
          numLabel.textContent = `${index + 1}`;
          numLabel.setAttribute("fill", color);
          numLabel.setAttribute("opacity", "0.35");
        }

        card?.addEventListener("click", () => {
          if (swapping) return;
          swapping = true;

          // Exit right — animate the whole #bot group (character + shadow together)
          animate("#bot", {
            translateX: 1800,
            duration: 500,
            ease: "inQuad",
            onComplete: () => {
              // Swap appearance while fully off-screen
              botIndex = (botIndex + 1) % 11;
              setBot(botIndex);

              // Pause, then re-enter from right
              setTimeout(() => {
                animate("#bot", {
                  translateX: 0,
                  duration: 500,
                  ease: "outQuad",
                  onComplete: () => {
                    swapping = false;
                  },
                });
              }, 1500);
            },
          });
        });
      }

      // --- Globe ---
      let globeInstance: Globe | null = null;
      let globePhi = 0;
      let globeSpeed = 0.003;

      function initGlobe(): void {
        const canvas = document.getElementById(
          "globe-canvas",
        ) as HTMLCanvasElement;
        if (!canvas) return;
        const locs: [number, number][] = JSON.parse(
          canvas.dataset.locations || "[]",
        );

        globeInstance = createGlobe(canvas, {
          devicePixelRatio: 2,
          width: 240,
          height: 240,
          phi: 0,
          theta: 0.15,
          dark: 1,
          diffuse: 1.2,
          mapSamples: 16000,
          mapBrightness: 4,
          mapBaseBrightness: 0.02,
          baseColor: [0.12, 0.16, 0.26],
          markerColor: [0.29, 0.87, 0.5],
          glowColor: [0.08, 0.12, 0.2],
          scale: 1,
          offset: [0, 0],
          markers: locs.map((loc) => ({ location: loc, size: 0.06 })),
        });

        function spin() {
          globePhi += globeSpeed;
          globeInstance?.update({ phi: globePhi });
          requestAnimationFrame(spin);
        }
        spin();
      }

      // --- Activate all cards ---
      function activateCards(): void {
        const cards =
          document.querySelectorAll<HTMLElement>("[data-stat-card]");

        // Fade in all cards together
        animate(cards, {
          opacity: [0, 1],
          translateY: [12, 0],
          duration: 600,
          ease: "outQuad",
          delay: stagger(100),
        });

        // Count up all numbers
        cards.forEach((card) => {
          const numEl = card.querySelector<HTMLElement>("[data-count-target]");
          if (numEl) countUp(numEl, numEl.dataset.countTarget || "0", 1200);
        });

        // Galaxy: init PixiJS + fade in
        initCardGalaxy();
        const galaxy = document.querySelector<HTMLElement>(
          ".card-graphic--galaxy",
        );
        if (galaxy) {
          animate(galaxy, {
            opacity: [0, 1],
            duration: 800,
            delay: 200,
            ease: "outQuad",
          });
        }

        // Scatter dots: pop in
        const dots =
          document.querySelectorAll<SVGCircleElement>(".scatter-dot");
        dots.forEach((dot) => {
          const targetR = parseFloat(dot.dataset.targetR || "2");
          const targetOp = parseFloat(dot.dataset.targetOpacity || "0.5");
          animate(dot, {
            r: [0, targetR],
            opacity: [0, targetOp],
            duration: 400,
            delay: stagger(15),
            ease: "outBack",
          });
        });

        // Globe: init
        initGlobe();

        // Robot: init PixiJS scene
        initRobot();
      }

      // --- Hover effects (subtle) ---
      function setupHoverEffects(): void {
        // Galaxy: twinkle particles on hover
        const galaxyCard = document.querySelector(
          '.stat-card[data-accent="cyan"]',
        );
        if (galaxyCard) {
          galaxyCard.addEventListener("mouseenter", () => {
            cardGalaxyTwinkle = true;
          });
          galaxyCard.addEventListener("mouseleave", () => {
            cardGalaxyTwinkle = false;
            // Restore original alphas
            for (const { particle, baseAlpha } of cardGalaxyDots) {
              particle.alpha = baseAlpha;
            }
          });
        }

        // Scatter: dots brighten
        const scatterCard = document.querySelector('[data-accent="magenta"]');
        if (scatterCard) {
          scatterCard.addEventListener("mouseenter", () => {
            animate(".scatter-dot", {
              opacity: 0.9,
              duration: 300,
              ease: "outQuad",
            });
          });
          scatterCard.addEventListener("mouseleave", () => {
            document
              .querySelectorAll<SVGCircleElement>(".scatter-dot")
              .forEach((dot) => {
                const targetOp = parseFloat(dot.dataset.targetOpacity || "0.5");
                animate(dot, {
                  opacity: targetOp,
                  duration: 400,
                  ease: "outQuad",
                });
              });
          });
        }

        // Globe: speed up on hover
        const globeCard = document.querySelector('[data-accent="green"]');
        if (globeCard) {
          globeCard.addEventListener("mouseenter", () => {
            globeSpeed = 0.008;
          });
          globeCard.addEventListener("mouseleave", () => {
            globeSpeed = 0.003;
          });
        }

        // Robot: handled by PixiJS internally
      }

      // --- Click easter eggs ---
      function setupClickEasterEggs(): void {
        // Galaxy: burst spin on click
        const galaxyClickCard = document.querySelector(
          '.stat-card[data-accent="cyan"]',
        );
        if (galaxyClickCard) {
          galaxyClickCard.addEventListener("click", () => {
            // Ramp up speed then ease back down
            cardGalaxySpeed = 0.02;
            setTimeout(() => {
              cardGalaxySpeed = 0.008;
            }, 400);
            setTimeout(() => {
              cardGalaxySpeed = 0.003;
            }, 800);
            setTimeout(() => {
              cardGalaxySpeed = 0.001;
            }, 1200);
          });
        }

        // Scatter: re-randomize dot positions
        const scatterCard = document.querySelector('[data-accent="magenta"]');
        if (scatterCard) {
          scatterCard.addEventListener("click", () => {
            document
              .querySelectorAll<SVGCircleElement>(".scatter-dot")
              .forEach((dot) => {
                animate(dot, {
                  cx: 12 + Math.random() * 178,
                  cy: 10 + Math.random() * 78,
                  duration: 600,
                  ease: "inOutBack(1.7)",
                });
              });
          });
        }

        // Globe: zoom pulse
        const globeCard = document.querySelector('[data-accent="green"]');
        if (globeCard) {
          globeCard.addEventListener("click", () => {
            const canvas = document.getElementById("globe-canvas");
            if (canvas) {
              animate(canvas, {
                scale: [1, 1.2, 1],
                duration: 800,
                ease: "outBack",
              });
            }
          });
        }

        // Robot: handled by PixiJS internally
      }

      // --- Init ---
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (!prefersReducedMotion) {
        // Scroll-triggered activation
        const stack = document.getElementById("stats-stack");
        if (stack) {
          onScroll({
            target: stack,
            enter: "bottom top",
            onEnter: () => {
              activateCards();
            },
          });
        }
      } else {
        // Reduced motion: show final state
        document
          .querySelectorAll<HTMLElement>("[data-stat-card]")
          .forEach((card) => {
            card.style.opacity = "1";
            card.style.transform = "none";
            const numEl = card.querySelector<HTMLElement>(
              "[data-count-target]",
            );
            if (numEl) numEl.textContent = numEl.dataset.countTarget || "0";
          });
        const galaxy = document.querySelector<HTMLElement>(
          ".card-graphic--galaxy",
        );
        if (galaxy) galaxy.style.opacity = "1";
        initCardGalaxy();
        document
          .querySelectorAll<SVGCircleElement>(".scatter-dot")
          .forEach((dot) => {
            dot.setAttribute("r", dot.dataset.targetR || "2");
            dot.setAttribute("opacity", dot.dataset.targetOpacity || "0.5");
          });
        initGlobe();
        initRobot();
      }

      setupHoverEffects();
      setupClickEasterEggs();
    </script>
  </body>
</html>
