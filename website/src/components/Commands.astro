---
<section class="grid grid-cols-1 md:grid-cols-3 gap-4">
  <div class="data-border bg-slate-900/50 p-6 space-y-4 border-t-4 border-t-[var(--neon-magenta)]">
    <div class="text-[var(--neon-magenta)] font-mono text-[10px] tracking-widest">COMMAND_LIST</div>
    <code class="block text-white text-sm font-mono">$ models list --provider anthropic</code>
    <p class="text-[10px] font-mono text-slate-500 uppercase">FILTER MODELS BY PROVIDER ENDPOINT</p>
  </div>
  <div class="data-border bg-slate-900/50 p-6 space-y-4 border-t-4 border-t-[var(--neon-magenta)]">
    <div class="text-[var(--neon-magenta)] font-mono text-[10px] tracking-widest">COMMAND_INSPECT</div>
    <code class="block text-white text-sm font-mono">$ models benchmarks show gpt-4o</code>
    <p class="text-[10px] font-mono text-slate-500 uppercase">DEEP DIVE ON ANY MODEL BENCHMARK</p>
  </div>
  <div class="data-border bg-slate-900/50 p-6 space-y-4 border-t-4 border-t-[var(--neon-magenta)]">
    <div class="text-[var(--neon-magenta)] font-mono text-[10px] tracking-widest">COMMAND_BENCH</div>
    <code class="block text-white text-sm font-mono">$ agents status</code>
    <p class="text-[10px] font-mono text-slate-500 uppercase">CHECK INSTALLED AGENT VERSIONS</p>
  </div>
</section>
