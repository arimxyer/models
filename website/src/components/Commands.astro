---

<section id="commands-section" class="grid grid-cols-1 gap-4 md:grid-cols-3">
  <div
    class="data-border space-y-4 border-t-4 border-t-(--neon-magenta) bg-slate-900/50 p-6"
    data-command-card
  >
    <div class="font-mono text-[10px] tracking-widest text-(--neon-magenta)">
      COMMAND_FILTER
    </div>
    <code class="block font-mono text-sm text-white"
      >$ models list --provider anthropic</code
    >
    <p class="font-mono text-[10px] text-slate-400 uppercase">
      FILTER MODELS BY PROVIDER ENDPOINT
    </p>
  </div>
  <div
    class="data-border space-y-4 border-t-4 border-t-(--neon-magenta) bg-slate-900/50 p-6"
    data-command-card
  >
    <div class="font-mono text-[10px] tracking-widest text-(--neon-magenta)">
      COMMAND_BENCHMARK
    </div>
    <code class="block font-mono text-sm text-white"
      >$ models benchmarks show gpt-4o</code
    >
    <p class="font-mono text-[10px] text-slate-400 uppercase">
      DEEP DIVE ON ANY MODEL BENCHMARK
    </p>
  </div>
  <div
    class="data-border space-y-4 border-t-4 border-t-(--neon-magenta) bg-slate-900/50 p-6"
    data-command-card
  >
    <div class="font-mono text-[10px] tracking-widest text-(--neon-magenta)">
      COMMAND_STATUS
    </div>
    <code class="block font-mono text-sm text-white">$ agents status</code>
    <p class="font-mono text-[10px] text-slate-400 uppercase">
      CHECK INSTALLED AGENT VERSIONS
    </p>
  </div>
</section>

<script>
  import { waapi, stagger, onScroll } from "animejs";

  function initCommands() {
    const section = document.getElementById("commands-section");
    if (!section || section.hasAttribute("data-commands-init")) return;
    section.setAttribute("data-commands-init", "true");

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReducedMotion) return;

    const cards = section.querySelectorAll<HTMLElement>("[data-command-card]");
    cards.forEach((card) => {
      card.style.opacity = "0";
      card.style.transform = "translateY(16px)";
    });

    onScroll({
      target: section,
      enter: "bottom top",
      onEnter: () => {
        waapi.animate(cards, {
          opacity: [0, 1],
          translateY: [16, 0],
          duration: 600,
          ease: "outQuad",
          delay: stagger(80),
        });
      },
    });
  }

  initCommands();
  document.addEventListener("astro:page-load", initCommands);
</script>
