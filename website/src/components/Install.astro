---

---

<section class="grid grid-cols-1 gap-4 lg:grid-cols-4">
  <div class="data-border bg-[var(--neon-green)] p-6 lg:col-span-1">
    <h2
      class="text-4xl leading-[0.9] font-black text-slate-900 uppercase italic"
    >
      System<br />Access
    </h2>
  </div>
  <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:col-span-3">
    <div
      class="data-border group flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-[var(--neon-green)]/10"
    >
      <span class="text-sm font-bold tracking-widest uppercase">Homebrew</span>
      <code
        class="font-mono text-xs text-slate-500 transition-colors group-hover:text-[var(--neon-green)]"
        >brew install models</code
      >
    </div>
    <div
      class="data-border group flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-[var(--neon-green)]/10"
    >
      <span class="text-sm font-bold tracking-widest uppercase">Cargo</span>
      <code
        class="font-mono text-xs text-slate-500 transition-colors group-hover:text-[var(--neon-green)]"
        >cargo install modelsdev</code
      >
    </div>
    <div
      class="data-border group flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-[var(--neon-green)]/10"
    >
      <span class="text-sm font-bold tracking-widest uppercase">Scoop</span>
      <code
        class="font-mono text-xs text-slate-500 transition-colors group-hover:text-[var(--neon-green)]"
        >scoop install extras/models</code
      >
    </div>
    <div
      class="data-border group flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-[var(--neon-green)]/10"
    >
      <span class="text-sm font-bold tracking-widest uppercase">AUR</span>
      <code
        class="font-mono text-xs text-slate-500 transition-colors group-hover:text-[var(--neon-green)]"
        >paru -S models-bin</code
      >
    </div>
  </div>
</section>
<div class="py-4">
  <a
    class="group inline-flex items-center gap-4 font-mono font-bold tracking-widest text-[var(--neon-cyan)] uppercase transition-all hover:text-white"
    href="https://github.com/arimxyer/models/releases"
  >
    <span class="text-xl">GitHub_Releases</span>
    <span class="transition-transform group-hover:translate-x-2">→</span>
  </a>
</div>
