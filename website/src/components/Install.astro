---
import { RELEASES_URL } from "@/data/site";
import { ClipboardCopy, Check } from "@lucide/astro";
import Button from "@/components/bearnie/button/Button.astro";
import Tooltip from "@/components/bearnie/tooltip/Tooltip.astro";
import TooltipContent from "@/components/bearnie/tooltip/TooltipContent.astro";
---

<section class="grid grid-cols-1 gap-4 lg:grid-cols-4">
  <div class="data-border bg-(--neon-green) p-6 lg:col-span-1">
    <h2
      class="text-4xl leading-[0.9] font-black text-slate-900 uppercase italic"
    >
      System<br />Access
    </h2>
  </div>
  <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:col-span-3">
    <!-- Homebrew -->
    <Tooltip class="w-full">
      <Button
        variant="ghost"
        class="data-border group relative flex h-auto w-full cursor-pointer flex-col items-start gap-2 rounded-none border-0 bg-transparent p-4 text-left transition-colors hover:bg-(--neon-green)/10 focus-visible:ring-2 focus-visible:ring-(--neon-cyan) focus-visible:outline-none sm:flex-row sm:items-center sm:justify-between"
        data-copy-btn
        data-copy-text="brew install models"
        aria-label="Copy install command: brew install models"
        data-tooltip-trigger
      >
        <span class="text-sm font-bold tracking-widest uppercase">Homebrew</span
        >
        <div
          class="flex w-full justify-between gap-2 sm:w-auto sm:justify-start"
        >
          <code
            class="font-mono text-xs break-all text-slate-400 transition-colors group-hover:text-(--neon-green) sm:break-normal"
            >brew install models</code
          >
          <div class="relative size-3.5 shrink-0 text-slate-400">
            <ClipboardCopy
              class="clipboard-icon absolute inset-0 transition-opacity duration-200"
              aria-hidden="true"
            />
            <Check
              class="check-icon absolute inset-0 opacity-0 transition-opacity duration-200"
              aria-hidden="true"
            />
          </div>
        </div>
      </Button>
      <TooltipContent side="top">Click to copy</TooltipContent>
    </Tooltip>

    <!-- Cargo -->
    <Tooltip class="w-full">
      <Button
        variant="ghost"
        class="data-border group relative flex h-auto w-full cursor-pointer flex-col items-start gap-2 rounded-none border-0 bg-transparent p-4 text-left transition-colors hover:bg-(--neon-green)/10 focus-visible:ring-2 focus-visible:ring-(--neon-cyan) focus-visible:outline-none sm:flex-row sm:items-center sm:justify-between"
        data-copy-btn
        data-copy-text="cargo install modelsdev"
        aria-label="Copy install command: cargo install modelsdev"
        data-tooltip-trigger
      >
        <span class="text-sm font-bold tracking-widest uppercase">Cargo</span>
        <div
          class="flex w-full justify-between gap-2 sm:w-auto sm:justify-start"
        >
          <code
            class="font-mono text-xs break-all text-slate-400 transition-colors group-hover:text-(--neon-green) sm:break-normal"
            >cargo install modelsdev</code
          >
          <div class="relative size-3.5 shrink-0 text-slate-400">
            <ClipboardCopy
              class="clipboard-icon absolute inset-0 transition-opacity duration-200"
              aria-hidden="true"
            />
            <Check
              class="check-icon absolute inset-0 opacity-0 transition-opacity duration-200"
              aria-hidden="true"
            />
          </div>
        </div>
      </Button>
      <TooltipContent side="top">Click to copy</TooltipContent>
    </Tooltip>

    <!-- Scoop -->
    <Tooltip class="w-full">
      <Button
        variant="ghost"
        class="data-border group relative flex h-auto w-full cursor-pointer flex-col items-start gap-2 rounded-none border-0 bg-transparent p-4 text-left transition-colors hover:bg-(--neon-green)/10 focus-visible:ring-2 focus-visible:ring-(--neon-cyan) focus-visible:outline-none sm:flex-row sm:items-center sm:justify-between"
        data-copy-btn
        data-copy-text="scoop install extras/models"
        aria-label="Copy install command: scoop install extras/models"
        data-tooltip-trigger
      >
        <span class="text-sm font-bold tracking-widest uppercase">Scoop</span>
        <div
          class="flex w-full justify-between gap-2 sm:w-auto sm:justify-start"
        >
          <code
            class="font-mono text-xs break-all text-slate-400 transition-colors group-hover:text-(--neon-green) sm:break-normal"
            >scoop install extras/models</code
          >
          <div class="relative size-3.5 shrink-0 text-slate-400">
            <ClipboardCopy
              class="clipboard-icon absolute inset-0 transition-opacity duration-200"
              aria-hidden="true"
            />
            <Check
              class="check-icon absolute inset-0 opacity-0 transition-opacity duration-200"
              aria-hidden="true"
            />
          </div>
        </div>
      </Button>
      <TooltipContent side="top">Click to copy</TooltipContent>
    </Tooltip>

    <!-- AUR -->
    <Tooltip class="w-full">
      <Button
        variant="ghost"
        class="data-border group relative flex h-auto w-full cursor-pointer flex-col items-start gap-2 rounded-none border-0 bg-transparent p-4 text-left transition-colors hover:bg-(--neon-green)/10 focus-visible:ring-2 focus-visible:ring-(--neon-cyan) focus-visible:outline-none sm:flex-row sm:items-center sm:justify-between"
        data-copy-btn
        data-copy-text="paru -S models-bin"
        aria-label="Copy install command: paru -S models-bin"
        data-tooltip-trigger
      >
        <span class="text-sm font-bold tracking-widest uppercase">AUR</span>
        <div
          class="flex w-full justify-between gap-2 sm:w-auto sm:justify-start"
        >
          <code
            class="font-mono text-xs break-all text-slate-400 transition-colors group-hover:text-(--neon-green) sm:break-normal"
            >paru -S models-bin</code
          >
          <div class="relative size-3.5 shrink-0 text-slate-400">
            <ClipboardCopy
              class="clipboard-icon absolute inset-0 transition-opacity duration-200"
              aria-hidden="true"
            />
            <Check
              class="check-icon absolute inset-0 opacity-0 transition-opacity duration-200"
              aria-hidden="true"
            />
          </div>
        </div>
      </Button>
      <TooltipContent side="top">Click to copy</TooltipContent>
    </Tooltip>
  </div>
</section>
<div class="py-4">
  <a
    class="group inline-flex items-center gap-4 font-mono font-bold tracking-widest text-(--neon-cyan) uppercase transition-colors hover:text-white focus-visible:text-white"
    href={RELEASES_URL}
    rel="noopener noreferrer"
  >
    <span class="text-xl">GitHub_Releases</span>
    <span class="transition-transform group-hover:translate-x-2">→</span>
  </a>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-copy-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy-text");
      if (!text) return;

      try {
        await navigator.clipboard.writeText(text);
      } catch {
        return;
      }

      // Find icon elements within the button
      const clipboardIcon = btn.querySelector<SVGElement>(".clipboard-icon");
      const checkIcon = btn.querySelector<SVGElement>(".check-icon");

      if (clipboardIcon && checkIcon) {
        clipboardIcon.style.opacity = "0";
        checkIcon.style.opacity = "1";

        setTimeout(() => {
          clipboardIcon.style.opacity = "1";
          checkIcon.style.opacity = "0";
        }, 1800);
      }

      // @ts-ignore
      window.toast?.success?.("Copied!");
    });
  });
</script>
