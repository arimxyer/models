---
import { WIKI_URL, REPO_URL, LICENSE_URL } from "@/data/site";
---

<header
  class="data-header sticky top-0 z-50 flex w-full items-center justify-between px-6 py-3 backdrop-blur-md"
>
  <div class="flex items-center gap-4">
    <div
      class="h-3 w-3 bg-[var(--neon-cyan)] motion-safe:animate-pulse"
      aria-hidden="true"
    >
    </div>
    <span class="text-sm font-black tracking-[0.2em] uppercase"
      >System: Models_OS</span
    >
  </div>
  <nav
    class="flex gap-8 font-mono text-[10px] tracking-widest uppercase"
    aria-label="Main navigation"
  >
    <a
      class="text-[var(--neon-cyan)] transition-colors hover:text-white focus-visible:text-white"
      href={WIKI_URL}
      rel="noopener noreferrer">[ documentation ]</a
    >
    <a
      class="text-slate-400 transition-colors hover:text-white focus-visible:text-white"
      href={REPO_URL}
      rel="noopener noreferrer">[ source_code ]</a
    >
    <a
      class="text-slate-400 transition-colors hover:text-white focus-visible:text-white"
      href={LICENSE_URL}
      rel="noopener noreferrer">[ license ]</a
    >
  </nav>
</header>
