        <div class="w-2 h-2 bg-[var(--neon-green)] opacity-50"></div>
        <div class="w-2 h-2 bg-[var(--neon-green)]"></div>
        <div class="w-2 h-2 bg-[var(--neon-green)]"></div>
        <div class="w-2 h-2 bg-[var(--neon-green)] opacity-10"></div>
      </div>
    </div>
  </div>
