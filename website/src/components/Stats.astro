<div class="grid grid-rows-3 gap-4 lg:col-span-4">
  <div class="data-border flex flex-col justify-between bg-slate-900/50 p-6">
    <span class="font-mono text-[10px] tracking-widest text-slate-500 uppercase"
      >Model_Density</span
    >
    <div class="flex items-end gap-2">
      <span class="glow-cyan text-5xl font-black text-[var(--neon-cyan)]"
        >4,000+</span
      >
      <div class="mb-2 flex gap-1">
        <div class="h-8 w-1 bg-[var(--neon-cyan)]"></div>
        <div class="h-6 w-1 bg-[var(--neon-cyan)] opacity-60"></div>
        <div class="h-10 w-1 bg-[var(--neon-cyan)]"></div>
      </div>
    </div>
  </div>
  <div class="data-border flex flex-col justify-between bg-slate-900/50 p-6">
    <span class="font-mono text-[10px] tracking-widest text-slate-500 uppercase"
      >Bench_Validation</span
    >
    <div class="flex items-end gap-2">
      <span class="glow-magenta text-5xl font-black text-[var(--neon-magenta)]"
