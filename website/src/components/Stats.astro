    <div class="flex items-end gap-2">
      <span class="text-5xl font-black text-[var(--neon-cyan)] glow-cyan">4,000+</span>
      <div class="flex gap-1 mb-2">
        <div class="w-1 h-8 bg-[var(--neon-cyan)]"></div>
        <div class="w-1 h-6 bg-[var(--neon-cyan)] opacity-60"></div>
        <div class="w-1 h-10 bg-[var(--neon-cyan)]"></div>
      </div>
    </div>
  </div>
  <div class="data-border bg-slate-900/50 p-6 flex flex-col justify-between">
    <span class="text-[10px] font-mono uppercase text-slate-500 tracking-widest">Bench_Validation</span>
