      <div class="grid grid-cols-4 gap-1">
        <div class="h-2 w-2 bg-[var(--neon-green)]"></div>
        <div class="h-2 w-2 bg-[var(--neon-green)] opacity-20"></div>
        <div class="h-2 w-2 bg-[var(--neon-green)]"></div>
        <div class="h-2 w-2 bg-[var(--neon-green)]"></div>
        <div class="h-2 w-2 bg-[var(--neon-green)] opacity-50"></div>
        <div class="h-2 w-2 bg-[var(--neon-green)]"></div>
        <div class="h-2 w-2 bg-[var(--neon-green)]"></div>
        <div class="h-2 w-2 bg-[var(--neon-green)] opacity-10"></div>
      </div>
    </div>
