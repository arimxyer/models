---
import { VERSION, REPO_URL, WIKI_URL, CRATES_URL } from "@/data/site";

const year = new Date().getFullYear();
---

<footer
  class="mt-20 border-t border-[var(--neon-cyan)]/20 bg-black/40 p-8 backdrop-blur-md"
>
  <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
    <div class="space-y-4">
      <div class="text-2xl font-black tracking-tighter text-white">MODELS</div>
      <p class="font-mono text-[10px] text-slate-400">
        RUNTIME: RUST_TOKIO_ASYNC<br />FRAMEWORK: RATATUI_CROSSTERM<br />CRATE:
        MODELSDEV
      </p>
    </div>
    <div class="space-y-2">
      <span
        class="block font-mono text-[10px] tracking-widest text-slate-400 uppercase"
        >Navigation</span
      >
      <ul class="space-y-1 font-mono text-xs uppercase">
        <li>
          <a
            class="transition-colors hover:text-[var(--neon-cyan)] focus-visible:text-[var(--neon-cyan)]"
            href={REPO_URL}
            rel="noopener noreferrer">Github_Repo</a
          >
        </li>
        <li>
          <a
            class="transition-colors hover:text-[var(--neon-cyan)] focus-visible:text-[var(--neon-cyan)]"
            href={WIKI_URL}
            rel="noopener noreferrer">Docs_Index</a
          >
        </li>
        <li>
          <a
            class="transition-colors hover:text-[var(--neon-cyan)] focus-visible:text-[var(--neon-cyan)]"
            href={CRATES_URL}
            rel="noopener noreferrer">Crates.io</a
          >
        </li>
        <li>VER: v{VERSION}</li>
      </ul>
    </div>
    <div class="space-y-2">
      <span
        class="block font-mono text-[10px] tracking-widest text-slate-400 uppercase"
        >Environment</span
      >
      <ul class="space-y-1 font-mono text-xs uppercase">
        <li>OS: DARWIN_LINUX_WIN</li>
        <li>LICENSE: MIT_OPEN_SOURCE</li>
      </ul>
    </div>
    <div class="flex items-end md:justify-end">
      <span class="font-mono text-[10px] text-slate-400"
        >© {year} MODELS. MIT LICENSE.</span
      >
    </div>
  </div>
</footer>
